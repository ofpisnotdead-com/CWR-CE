<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	CloudSync (engine/Poseidon/Core/CloudSync) syncs profiles/saves/editor
	missions through this container across a player's Apple devices. The
	"iCloud" capability + this container must be enabled on App ID
	io.mcardle.cwr in the Apple Developer portal before these keys have any
	effect -- until then, NSFileManager.URLForUbiquityContainerIdentifier:
	returns nil and CloudSync::IsAvailable() stays false everywhere.
	-->
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array>
		<string>iCloud.io.mcardle.cwr</string>
	</array>
	<key>com.apple.developer.icloud-services</key>
	<array>
		<string>CloudDocuments</string>
	</array>
	<key>com.apple.developer.ubiquity-container-identifiers</key>
	<array>
		<string>iCloud.io.mcardle.cwr</string>
	</array>
</dict>
</plist>
